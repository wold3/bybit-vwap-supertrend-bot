//@version=6
strategy("VWAP + SuperTrend Webhook Bot", overlay=true, initial_capital=1000)

//==================================================
// Inputs
//==================================================

st_length = input.int(10, "SuperTrend ATR Length")
st_mult   = input.float(3.0, "SuperTrend Multiplier")

qty       = input.float(0.001, "Order Qty")

showLabel = input.bool(true, "Show Labels")

//==================================================
// Indicators
//==================================================

vwap_val = ta.vwap(hlc3)
[st_line, st_dir] = ta.supertrend(st_mult, st_length)

//==================================================
// Plot
//==================================================

plot(vwap_val, "VWAP", color=color.yellow, linewidth=2)
plot(st_line, "SuperTrend", color=st_dir < 0 ? color.green : color.red)

//==================================================
// Signal Logic (confirmed bar only)
//==================================================

longCond  = barstate.isconfirmed and st_dir[1] < 0 and low[1] > vwap_val[1]
shortCond = barstate.isconfirmed and st_dir[1] > 0 and high[1] < vwap_val[1]

exitLong  = barstate.isconfirmed and st_dir[1] > 0
exitShort = barstate.isconfirmed and st_dir[1] < 0

//==================================================
// JSON builder
//==================================================

f_json(_signal) =>
    '{"signal":"' + _signal + '","symbol":"' + syminfo.ticker + '","qty":' + str.tostring(qty) + '}'

//==================================================
// Orders (strategy backtest optional)
//==================================================

if longCond
    strategy.close("SHORT")
    strategy.entry("LONG", strategy.long)

    alert(f_json("BUY"), alert.freq_once_per_bar_close)

if shortCond
    strategy.close("LONG")
    strategy.entry("SHORT", strategy.short)

    alert(f_json("SHORT"), alert.freq_once_per_bar_close)

if exitLong
    strategy.close("LONG")
    alert(f_json("SELL"), alert.freq_once_per_bar_close)

if exitShort
    strategy.close("SHORT")
    alert(f_json("EXIT"), alert.freq_once_per_bar_close)

//==================================================
// Labels
//==================================================

if showLabel and longCond
    label.new(bar_index, low, "BUY", style=label.style_label_up, color=color.green, textcolor=color.white)

if showLabel and shortCond
    label.new(bar_index, high, "SHORT", style=label.style_label_down, color=color.red, textcolor=color.white)

if showLabel and exitLong
    label.new(bar_index, high, "SELL", style=label.style_label_down, color=color.blue, textcolor=color.white)

if showLabel and exitShort
    label.new(bar_index, low, "EXIT", style=label.style_label_up, color=color.orange, textcolor=color.white)
