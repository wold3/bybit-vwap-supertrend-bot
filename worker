from services.event_bus import event_bus
from execution.execution_engine import engine
from execution.pnl_engine import pnl_engine
from risk.risk_engine import risk


def loop():

    while True:

        event = event_bus.get()

        if event["type"] != "TICK":
            continue

        symbol = event["symbol"]
        price = event["price"]

        signal = "Buy" if price % 2 == 0 else "Sell"

        engine.execute(symbol, signal, 1, price)

        pnl = pnl_engine.get(symbol)

        risk.update_pnl(pnl)

        print(f"[AUTO] {symbol} {price} PNL={pnl}")
