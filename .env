
# =================================================
# BYBIT CONFIG (실거래 / WS)
# =================================================
BYBIT_WS_URL=wss://stream.bybit.com/v5/public/linear
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# 거래 심볼
SYMBOL=BTCUSDT

# =================================================
# RISK CONFIG
# =================================================
MAX_DRAWDOWN=10
DAILY_LOSS_LIMIT=5

# =================================================
# STRATEGY CONFIG
# =================================================
VOLUME_WINDOW=20
VWAP_WINDOW=30
ML_THRESHOLD=0.55

# =================================================
# TELEGRAM ALERT
# =================================================
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# =================================================
# SYSTEM CONFIG
# =================================================
ENV=production
DEBUG=False
LOG_LEVEL=INFO
