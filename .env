# ==================================================
# BYBIT API
# ==================================================

BYBIT_API_KEY=YOUR_API_KEY

BYBIT_API_SECRET=YOUR_API_SECRET


# 실거래
# mainnet : https://api.bybit.com
# testnet : https://api-testnet.bybit.com

BYBIT_BASE_URL=https://api.bybit.com



# ==================================================
# TRADING MODE
# ==================================================

# true  = 실제 주문
# false = 테스트 모드

LIVE_TRADING=true



# ==================================================
# ACCOUNT
# ==================================================

# linear USDT perpetual

BYBIT_CATEGORY=linear


# 기본 거래 코인

DEFAULT_SYMBOL=BTCUSDT



# ==================================================
# ORDER SETTINGS
# ==================================================

ORDER_TYPE=Market


TIME_IN_FORCE=IOC


# 기본 주문 수량

DEFAULT_QTY=0.001





# ==================================================
# RISK MANAGEMENT
# ==================================================

# 최대 허용 Drawdown %

MAX_DRAWDOWN=10



# 1회 거래 리스크 %

RISK_PER_TRADE=1



# 최대 동시 포지션

MAX_POSITIONS=3





# ==================================================
# STOP LOSS / TAKE PROFIT
# ==================================================

STOP_LOSS_PERCENT=1


TAKE_PROFIT_PERCENT=2





# ==================================================
# TRAILING STOP
# ==================================================

TRAILING_STOP_ENABLE=true


TRAILING_STOP_PERCENT=0.5





# ==================================================
# STRATEGY
# ==================================================

# VWAP

VWAP_ENABLE=true



# Supertrend

SUPERTREND_ENABLE=true


SUPERTREND_PERIOD=10


SUPERTREND_MULTIPLIER=3





# ==================================================
# ML FILTER
# ==================================================

ML_FILTER_ENABLE=true


# 최소 진입 확률

ML_THRESHOLD=0.65





# ==================================================
# WEBSOCKET
# ==================================================

PUBLIC_WS_URL=wss://stream.bybit.com/v5/public/linear


PRIVATE_WS_URL=wss://stream.bybit.com/v5/private





# ==================================================
# DASHBOARD
# ==================================================

DASHBOARD_HOST=0.0.0.0


DASHBOARD_PORT=5000





# ==================================================
# DATABASE
# ==================================================

TRADE_DB=trades.db





# ==================================================
# LOGGING
# ==================================================

LOG_LEVEL=INFO





# ==================================================
# TELEGRAM (선택)
# ==================================================

TELEGRAM_ENABLE=false


TELEGRAM_BOT_TOKEN=


TELEGRAM_CHAT_ID=
