# =====================================
# BYBIT TESTNET API
# =====================================

BYBIT_API_KEY=YOUR_TESTNET_API_KEY

BYBIT_API_SECRET=YOUR_TESTNET_API_SECRET


# REST API
BYBIT_BASE_URL=https://api-testnet.bybit.com



# =====================================
# TRADING MODE
# =====================================

# Testnet 실제 주문 실행
LIVE_TRADING=true



# =====================================
# MARKET
# =====================================

DEFAULT_SYMBOL=BTCUSDT



# =====================================
# ORDER SETTINGS
# =====================================

# BTCUSDT 최소 테스트 수량 기준 확인 필요
DEFAULT_QTY=0.001

ORDER_RETRY=3



# =====================================
# RISK MANAGEMENT
# =====================================

# 하루 최대 주문 횟수
MAX_TRADES=5


# 최대 허용 손실
MAX_DAILY_LOSS=-20



# =====================================
# DRAWDOWN GUARD
# =====================================

MAX_DRAWDOWN=-20



# =====================================
# TRAILING STOP
# =====================================

USE_TRAILING_STOP=true


# 0.5%
TRAILING_STOP_PERCENT=0.5



# =====================================
# INDICATORS
# =====================================

# Supertrend
SUPER_TREND_PERIOD=10

SUPER_TREND_MULTIPLIER=3


# Candle 저장 개수
MAX_HISTORY=200



# =====================================
# ML FILTER
# =====================================

# 초기 테스트 OFF
USE_ML_FILTER=false



# =====================================
# WEBSOCKET
# =====================================

# Public Linear Testnet
BYBIT_PUBLIC_WS=wss://stream-testnet.bybit.com/v5/public/linear


# Private Testnet
BYBIT_PRIVATE_WS=wss://stream-testnet.bybit.com/v5/private



# =====================================
# DATABASE
# =====================================

TRADE_DB_PATH=trade_history.db
