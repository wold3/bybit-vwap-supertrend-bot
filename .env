# ======================================
# BYBIT API
# ======================================

BYBIT_API_KEY=YOUR_DEMO_API_KEY
BYBIT_API_SECRET=YOUR_DEMO_API_SECRET


# ======================================
# BYBIT MODE
# ======================================

# 실거래 여부
LIVE=false

# Bybit Demo Trading
BYBIT_DEMO=true

# Testnet 사용 여부
BYBIT_TESTNET=false


# ======================================
# ACCOUNT
# ======================================

ACCOUNT_TYPE=UNIFIED

CATEGORY=linear

SYMBOL=BTCUSDT

DEFAULT_SYMBOL=BTCUSDT


# ======================================
# TRADING
# ======================================

LEVERAGE=3


# 주문 수량 기본값
DEFAULT_QTY=0.001


# ======================================
# RISK MANAGEMENT
# ======================================

RISK_PER_TRADE_PERCENT=1.0

MAX_DRAWDOWN_PERCENT=10.0

MAX_LOSS_STREAK=5


# ======================================
# VWAP + SUPERTREND
# ======================================

VWAP_LENGTH=50

ST_LENGTH=10

SUPERTREND_PERIOD=10

SUPERTREND_MULTIPLIER=3.0


# Volume Filter

USE_VOLUME_FILTER=true

MIN_VOLUME_MULTIPLIER=1.2


# ======================================
# WATCHDOG
# ======================================

WATCHDOG_INTERVAL=30

MAX_API_ERROR=5


# ======================================
# DATABASE
# ======================================

DATABASE_ENABLED=true

DATABASE_PATH=trading.db


# ======================================
# TELEGRAM
# ======================================

TELEGRAM_ENABLED=false

TELEGRAM_TOKEN=

TELEGRAM_CHAT_ID=


# ======================================
# LOGGING
# ======================================

LOG_LEVEL=INFO
