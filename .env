BYBIT_API_KEY=9PGw3Wfn24npYXyMtL

BYBIT_API_SECRET=M93YPX7FFms4FLGR1GyjSi8QQBcS9VPM76tj


# Testnet REST API

BYBIT_BASE_URL=https://api-testnet.bybit.com


# Public WebSocket

BYBIT_PUBLIC_WS=wss://stream-testnet.bybit.com/v5/public/linear


# Private WebSocket

BYBIT_PRIVATE_WS=wss://stream-testnet.bybit.com/v5/private



# =====================================
# ACCOUNT / TRADING
# =====================================

# Unified Trading Account
ACCOUNT_TYPE=UNIFIED

# Linear Futures
CATEGORY=linear


# Trading mode
# false = 테스트 실행
# true  = 실제 주문
LIVE_TRADING=false


# Default Symbol

DEFAULT_SYMBOL=BTCUSDT



# =====================================
# ORDER SETTINGS
# =====================================

# 기본 주문 수량 BTC
DEFAULT_QTY=0.001


# 주문 재시도 횟수

ORDER_RETRY=3


# API 요청 timeout

REQUEST_TIMEOUT=10



# =====================================
# RISK MANAGEMENT
# =====================================

# 최대 거래 횟수

MAX_TRADES=100


# 최대 일일 손실

MAX_DAILY_LOSS=-50



# =====================================
# POSITION MANAGEMENT
# =====================================

# 포지션 체크 주기(sec)

POSITION_SYNC_INTERVAL=10



# =====================================
# TRAILING STOP
# =====================================

TRAILING_STOP_ENABLED=true

TRAILING_STOP_PERCENT=1.0



# =====================================
# MARKET DATA
# =====================================

# candle history

MAX_HISTORY=200


# candle timeframe(min)

TIMEFRAME=1



# =====================================
# INDICATORS
# =====================================

# SuperTrend

SUPER_TREND_PERIOD=10

SUPER_TREND_MULTIPLIER=3



# VWAP

VWAP_ENABLED=true



# =====================================
# ML FILTER
# =====================================

# false = 기본 전략
# true  = ML 필터 사용

USE_ML_FILTER=false



# =====================================
# DATABASE
# =====================================

DATABASE_FILE=trade_history.db



# =====================================
# WATCHDOG
# =====================================

WATCHDOG_TIMEOUT=60



# =====================================
# LOGGING
# =====================================

LOG_LEVEL=INFO



# =====================================
# SECURITY
# =====================================

RECV_WINDOW=5000
