# ==================================================
# BYBIT SERVER / MODE
# ==================================================

# true  : Testnet
# false : Demo Trading / Live

BYBIT_TESTNET=false

# Demo Trading 사용 여부
BYBIT_DEMO=true

# 실제 주문 활성화 여부
LIVE_TRADING=false


# ==================================================
# BYBIT URL
# ==================================================

BYBIT_BASE_URL=https://api-demo.bybit.com



# ==================================================
# WEBSOCKET
# ==================================================

# Demo Market Data

BYBIT_PUBLIC_WS=wss://stream-demo.bybit.com/v5/public


# Demo Private Account

BYBIT_PRIVATE_WS=wss://stream-demo.bybit.com/v5/private



# ==================================================
# ACCOUNT
# ==================================================

ACCOUNT_TYPE=UNIFIED

CATEGORY=linear



# ==================================================
# SYMBOL
# ==================================================

DEFAULT_SYMBOL=BTCUSDT



# ==================================================
# ORDER
# ==================================================

DEFAULT_QTY=0.001

ORDER_TYPE=Market

TIME_IN_FORCE=GTC


# 주문 재시도

ORDER_RETRY=3


# 동일 방향 재주문 방지 시간(초)

ORDER_COOLDOWN=60



# ==================================================
# LEVERAGE
# ==================================================

LEVERAGE=3



# ==================================================
# RISK MANAGEMENT
# ==================================================

# 최대 포지션 크기

MAX_POSITION_SIZE=0.001


# 하루 최대 손실 %

MAX_DAILY_LOSS_PERCENT=5


# 최대 누적 Drawdown %

MAX_DRAWDOWN_PERCENT=15


# 연속 손실 횟수 제한

MAX_LOSS_STREAK=5


# 한 거래당 위험 %

RISK_PER_TRADE_PERCENT=1



# ==================================================
# TP / SL
# ==================================================

# 고정 TP/SL 사용 시

TAKE_PROFIT_PERCENT=1.0

STOP_LOSS_PERCENT=0.5



# ==================================================
# INDICATOR
# ==================================================

VWAP_LENGTH=20


SUPERTREND_PERIOD=10


SUPERTREND_MULTIPLIER=3



# ATR

ATR_PERIOD=14



# ==================================================
# WATCHDOG
# ==================================================

# 상태 체크 주기

WATCHDOG_INTERVAL=30


# API 연속 오류 허용 횟수

MAX_API_ERROR=5



# ==================================================
# DATABASE
# ==================================================

DATABASE_PATH=data/bot.db



