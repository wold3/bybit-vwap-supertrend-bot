# =====================================
# TRADING MODE
# =====================================

# false = Demo Trading
# true  = Live Trading

LIVE_TRADING=false



# =====================================
# BYBIT API KEY
# =====================================

BYBIT_API_KEY=YOUR_API_KEY_HERE

BYBIT_API_SECRET=YOUR_API_SECRET_HERE



# =====================================
# BYBIT REST API
# =====================================

# LIVE
BYBIT_LIVE_BASE_URL=https://api.bybit.com

# DEMO
BYBIT_DEMO_BASE_URL=https://api-demo.bybit.com



# =====================================
# BYBIT PUBLIC WEBSOCKET
# =====================================

# LIVE PUBLIC WS

BYBIT_LIVE_PUBLIC_WS=wss://stream.bybit.com/v5/public/linear


# DEMO PUBLIC WS

BYBIT_DEMO_PUBLIC_WS=wss://stream-demo.bybit.com/v5/public/linear



# =====================================
# BYBIT PRIVATE WEBSOCKET
# =====================================

# LIVE PRIVATE WS

BYBIT_LIVE_PRIVATE_WS=wss://stream.bybit.com/v5/private


# DEMO PRIVATE WS

BYBIT_DEMO_PRIVATE_WS=wss://stream-demo.bybit.com/v5/private



# =====================================
# DEFAULT MARKET
# =====================================

DEFAULT_SYMBOL=BTCUSDT



# =====================================
# ORDER SETTINGS
# =====================================

ORDER_RETRY=3



# =====================================
# POSITION SETTINGS
# =====================================

DEFAULT_LEVERAGE=5

MAX_POSITION_SIZE=0.01



# =====================================
# CANDLE SETTINGS
# =====================================

CANDLE_INTERVAL=1



# =====================================
# RISK MANAGEMENT
# =====================================

MAX_DAILY_LOSS=5

MAX_OPEN_POSITION=1



# =====================================
# DATABASE
# =====================================

TRADE_DB_PATH=data/trades.db



# =====================================
# LOGGING
# =====================================

LOG_LEVEL=INFO
