```env
# ==================================
# BYBIT API
# ==================================

BYBIT_API_KEY=sLo3fcWX9C7aGD2P0j

BYBIT_API_SECRET=D0rel1YGg7ORgGr0DXW6p0XbLfiQBgdiP2Vy



# ==================================
# BYBIT SERVER
# ==================================

# Demo Trading
BYBIT_BASE_URL=https://api-demo.bybit.com



# ==================================
# TRADING MODE
# ==================================

# false = 테스트/데모
# true  = 실제 거래

LIVE_TRADING=false


# Bybit Testnet
BYBIT_TESTNET=false


# Bybit Demo Account
BYBIT_DEMO=true



# ==================================
# WEBSOCKET
# ==================================

# Public Market Data

BYBIT_PUBLIC_WS=wss://stream.bybit.com/v5/public


# Private Account Stream

BYBIT_PRIVATE_WS=wss://stream-demo.bybit.com/v5/private



# ==================================
# ACCOUNT
# ==================================

ACCOUNT_TYPE=UNIFIED


CATEGORY=linear



# ==================================
# SYMBOL
# ==================================

DEFAULT_SYMBOL=BTCUSDT



# ==================================
# ORDER SETTINGS
# ==================================

DEFAULT_QTY=0.001


ORDER_TYPE=Market


TIME_IN_FORCE=GTC


# 주문 후 추가 주문 제한 시간

ORDER_COOLDOWN=60


# API 주문 재시도 횟수

ORDER_RETRY=3



# ==================================
# LEVERAGE
# ==================================

LEVERAGE=3



# ==================================
# RISK MANAGEMENT
# ==================================

# 최대 보유 수량

MAX_POSITION_SIZE=0.001


# 하루 최대 손실 %

MAX_DAILY_LOSS_PERCENT=5


# 전체 최대 Drawdown %

MAX_DRAWDOWN_PERCENT=15


# 한 거래당 위험 %

RISK_PER_TRADE_PERCENT=1


# 연속 손실 제한

MAX_LOSS_STREAK=5



# ==================================
# TAKE PROFIT / STOP LOSS
# ==================================

TAKE_PROFIT_PERCENT=1.0


STOP_LOSS_PERCENT=0.5



# ==================================
# INDICATORS
# ==================================

VWAP_LENGTH=20


SUPERTREND_PERIOD=10


SUPERTREND_MULTIPLIER=3


ATR_PERIOD=14



# ==================================
# WATCHDOG
# ==================================

# 상태 확인 주기(초)

WATCHDOG_INTERVAL=30


# API 오류 허용 횟수

MAX_API_ERROR=5



# ==================================
# DATABASE
# ==================================

DATABASE_PATH=data/bot.db



# ==================================
# TELEGRAM
# ==================================

TELEGRAM_ENABLED=false


TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN


TELEGRAM_CHAT_ID=YOUR_CHAT_ID



# ==================================
# LOG
# ==================================

LOG_LEVEL=INFO
```

