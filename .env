#################################
# MODE
#################################

# false = 테스트
# true  = 실거래

LIVE_TRADING=false



#################################
# BYBIT API
#################################

BYBIT_API_KEY=YOUR_API_KEY

BYBIT_API_SECRET=YOUR_API_SECRET


# Mainnet
BYBIT_BASE_URL=https://api.bybit.com


# Testnet 사용시
# BYBIT_BASE_URL=https://api-testnet.bybit.com





#################################
# WEBSOCKET
#################################

PUBLIC_WS_URL=wss://stream.bybit.com/v5/public/linear

PRIVATE_WS_URL=wss://stream.bybit.com/v5/private





#################################
# SYMBOL
#################################

DEFAULT_SYMBOL=BTCUSDT


# 여러 코인 확장용

SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT





#################################
# KLINE
#################################

KLINE_INTERVAL=1





#################################
# ORDER
#################################

DEFAULT_QTY=0.001


ORDER_RETRY=3



# Market / Limit

ORDER_TYPE=Market





#################################
# STRATEGY
#################################

VWAP_ENABLE=true

SUPERTREND_ENABLE=true



# Supertrend

SUPERTREND_PERIOD=10

SUPERTREND_MULTIPLIER=3





#################################
# ML FILTER
#################################

ML_FILTER_ENABLE=true


# 최소 거래 확률

ML_THRESHOLD=0.65





#################################
# RISK MANAGEMENT
#################################

# 최대 허용 Drawdown %

MAX_DRAWDOWN=10



# 1회 거래 위험 %

RISK_PERCENT=1





#################################
# STOP LOSS / TAKE PROFIT
#################################

SL_ENABLE=true


TP_ENABLE=true



STOP_LOSS_PERCENT=1.5


TAKE_PROFIT_PERCENT=3





#################################
# TRAILING STOP
#################################

TRAILING_STOP_ENABLE=true


TRAILING_STOP_PERCENT=1.5





#################################
# DATABASE
#################################

TRADE_DB=trades.db





#################################
# DASHBOARD
#################################

DASHBOARD_HOST=0.0.0.0


DASHBOARD_PORT=5000





#################################
# LOG
#################################

LOG_LEVEL=INFO
