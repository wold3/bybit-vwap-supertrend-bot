BYBIT_API_KEY=sLo3fcWX9C7aGD2P0j
BYBIT_API_SECRET=D0rel1YGg7ORgGr0DXW6p0XbLfiQBgdiP2Vy


# ==================================
# BYBIT SERVER MODE
# ==================================

# Demo Trading
BYBIT_DEMO=true

# Testnet 사용 안 함
BYBIT_TESTNET=false

BYBIT_BASE_URL=https://api-demo.bybit.com



# ==================================
# TRADING MODE
# ==================================

LIVE_TRADING=false



# ==================================
# ACCOUNT
# ==================================

ACCOUNT_TYPE=UNIFIED

CATEGORY=linear



# ==================================
# WEBSOCKET
# ==================================

# Demo Public WS
BYBIT_PUBLIC_WS=wss://stream.bybit.com/v5/public/linear

# Demo Private WS
BYBIT_PRIVATE_WS=wss://stream-demo.bybit.com/v5/private



# ==================================
# SYMBOL
# ==================================

DEFAULT_SYMBOL=BTCUSDT



# ==================================
# ORDER
# ==================================

DEFAULT_QTY=0.001

ORDER_TYPE=Market

TIME_IN_FORCE=GTC

ORDER_COOLDOWN=60

ORDER_RETRY=3



# ==================================
# LEVERAGE
# ==================================

LEVERAGE=3



# ==================================
# RISK MANAGEMENT
# ==================================

MAX_POSITION_SIZE=0.001

RISK_PER_TRADE_PERCENT=1

MAX_DAILY_LOSS_PERCENT=5

MAX_DRAWDOWN_PERCENT=10

MAX_LOSS_STREAK=3



# ==================================
# STRATEGY
# ==================================

VWAP_LENGTH=20

ST_LENGTH=10

SUPERTREND_PERIOD=10

SUPERTREND_MULTIPLIER=3


# Volume Filter

USE_VOLUME_FILTER=true

MIN_VOLUME_MULTIPLIER=1.2



# ==================================
# WATCHDOG
# ==================================

WATCHDOG_INTERVAL=30

MAX_API_ERROR=5



# ==================================
# TP / SL
# ==================================

TAKE_PROFIT_PERCENT=1.0

STOP_LOSS_PERCENT=0.5



# ==================================
# DATABASE
# ==================================

DATABASE_PATH=data/trading.db



# ==================================
# LOG
# ==================================

LOG_LEVEL=INFO
