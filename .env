
# =================================================
# 🟢 ENV MODE
# =================================================
ENV=production
DEBUG=False
LOG_LEVEL=INFO

# =================================================
# 📡 BYBIT API (REAL TRADING)
# =================================================
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_BASE_URL=https://api.bybit.com

# WebSocket (실시간 시세)
BYBIT_WS_URL=wss://stream.bybit.com/v5/public/linear

# =================================================
# 📊 TRADE SETTINGS
# =================================================
SYMBOL=BTCUSDT
CATEGORY=linear

ORDER_TYPE=Market
TIME_IN_FORCE=IOC

DEFAULT_QTY=0.001

# =================================================
# 🚨 RISK MANAGEMENT (핵심)
# =================================================
MAX_DRAWDOWN=10
DAILY_LOSS_LIMIT=5
MAX_POSITION_SIZE=0.01
MAX_OPEN_POSITIONS=1

ENABLE_TRADING=true

# =================================================
# 🤖 STRATEGY SETTINGS
# =================================================
VWAP_WINDOW=30
SUPER_TREND_PERIOD=10

ML_THRESHOLD=0.55

MIN_SIGNAL_SCORE=0.5

# =================================================
# 📈 PORTFOLIO MODE (멀티코인 확장 대비)
# =================================================
ENABLE_MULTI_ASSET=true
ASSETS=BTCUSDT,ETHUSDT,SOLUSDT

# =================================================
# 📡 TELEGRAM ALERTS
# =================================================
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

ENABLE_TG_ALERT=true

# =================================================
# ⚙️ SYSTEM SAFETY
# =================================================
AUTO_RESTART=true
WATCHDOG_ENABLED=true

RETRY_ORDER_ON_FAIL=true
MAX_RETRY=3

# =================================================
# 🧪 TEST MODE (중요)
# =================================================
TESTNET=false
PAPER_TRADING=false
