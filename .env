# =====================================
# MODE
# =====================================

# false = Demo Trading
# true  = Real Trading

LIVE_TRADING=false



# =====================================
# REST API
# =====================================

# Demo
BYBIT_DEMO_BASE_URL=https://api-demo.bybit.com

# Live
BYBIT_LIVE_BASE_URL=https://api.bybit.com


# 현재 사용 BASE URL
BYBIT_BASE_URL=https://api-demo.bybit.com



# =====================================
# WEBSOCKET
# =====================================

# Demo Public WS
BYBIT_DEMO_PUBLIC_WS=wss://stream-demo.bybit.com/v5/public/linear

# Live Public WS
BYBIT_LIVE_PUBLIC_WS=wss://stream.bybit.com/v5/public/linear


# Demo Private WS
BYBIT_DEMO_PRIVATE_WS=wss://stream-demo.bybit.com/v5/private

# Live Private WS
BYBIT_LIVE_PRIVATE_WS=wss://stream.bybit.com/v5/private


# 현재 Private WS
BYBIT_PRIVATE_WS=wss://stream-demo.bybit.com/v5/private



# =====================================
# ACCOUNT
# =====================================

ACCOUNT_TYPE=UNIFIED

CATEGORY=linear



# =====================================
# SYMBOL
# =====================================

DEFAULT_SYMBOL=BTCUSDT



# =====================================
# ORDER SETTINGS
# =====================================

# BTC 수량

DEFAULT_QTY=0.001


# 주문 재시도

ORDER_RETRY=3


# API timeout(sec)

REQUEST_TIMEOUT=10


# Receive window(ms)

RECV_WINDOW=5000



# =====================================
# POSITION
# =====================================

POSITION_SYNC_INTERVAL=10



# =====================================
# RISK MANAGEMENT
# =====================================

# 최대 동시 거래 횟수

MAX_TRADES=100


# 일일 최대 손실 USDT

MAX_DAILY_LOSS=-50



# =====================================
# STOP MANAGEMENT
# =====================================

TRAILING_STOP_ENABLED=true

TRAILING_STOP_PERCENT=1.0



# =====================================
# MARKET DATA
# =====================================

# candle 저장 개수

MAX_HISTORY=400


# candle timeframe(min)

TIMEFRAME=1



# =====================================
# INDICATORS
# =====================================

# SuperTrend

SUPER_TREND_PERIOD=400

SUPER_TREND_MULTIPLIER=15


# VWAP

VWAP_ENABLED=true



# =====================================
# STRATEGY
# =====================================

# 중복 신호 방지

SIGNAL_COOLDOWN=60


# 최소 candle 확보

MIN_CANDLE_COUNT=50



# =====================================
# MACHINE LEARNING
# =====================================

USE_ML_FILTER=false



# =====================================
# DATABASE
# =====================================

DATABASE_FILE=trade_history.db



# =====================================
# WATCHDOG
# =====================================

WATCHDOG_TIMEOUT=60



# =====================================
# LOGGING
# =====================================

LOG_LEVEL=INFO
