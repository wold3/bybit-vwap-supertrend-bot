# =====================================
# BYBIT API
# =====================================

BYBIT_API_KEY=YOUR_API_KEY

BYBIT_API_SECRET=YOUR_API_SECRET

BYBIT_BASE_URL=https://api.bybit.com



# =====================================
# TRADING MODE
# =====================================

# false = 테스트
# true  = 실제 주문

LIVE_TRADING=false



# =====================================
# SYMBOL
# =====================================

DEFAULT_SYMBOL=BTCUSDT



# =====================================
# ORDER
# =====================================

DEFAULT_QTY=0.001

ORDER_RETRY=3



# =====================================
# RISK
# =====================================

MAX_TRADES=100

MAX_DAILY_LOSS=-50



# =====================================
# DRAWDOWN
# =====================================

MAX_DRAWDOWN=-50



# =====================================
# TRAILING STOP
# =====================================

USE_TRAILING_STOP=true

TRAILING_STOP_PERCENT=0.5



# =====================================
# INDICATOR
# =====================================

SUPER_TREND_PERIOD=10

SUPER_TREND_MULTIPLIER=3

MAX_HISTORY=200



# =====================================
# ML FILTER
# =====================================

USE_ML_FILTER=false
