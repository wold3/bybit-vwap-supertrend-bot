############################################
# BYBIT API
############################################

BYBIT_API_KEY=YOUR_BYBIT_API_KEY

BYBIT_API_SECRET=YOUR_BYBIT_API_SECRET


# Bybit V5 Mainnet
BYBIT_BASE_URL=https://api.bybit.com



############################################
# TRADING MODE
############################################

# false = 테스트/검증
# true  = 실거래

LIVE_TRADING=false



############################################
# ORDER SETTINGS
############################################

# 기본 주문 수량
# BTCUSDT Linear 기준

DEFAULT_QTY=0.001


# 주문 실패 재시도 횟수

ORDER_RETRY=3





############################################
# MARKET SETTINGS
############################################

# Candle interval

CANDLE_INTERVAL=60


# Symbol

DEFAULT_SYMBOL=BTCUSDT





############################################
# RISK MANAGEMENT
############################################

# 최대 거래 횟수

MAX_TRADES=100


# 최대 일일 손실 금액

MAX_DAILY_LOSS=-50





############################################
# TRAILING STOP
############################################

# 사용 여부

USE_TRAILING_STOP=true


# Trail 비율 %

TRAILING_STOP_PERCENT=0.5





############################################
# INDICATOR SETTINGS
############################################

# Supertrend

SUPER_TREND_PERIOD=10

SUPER_TREND_MULTIPLIER=3



# Indicator history

MAX_HISTORY=200





############################################
# MACHINE LEARNING FILTER
############################################

# false = ML 통과

USE_ML_FILTER=false





############################################
# DATABASE
############################################

DB_PATH=trade_history.db





############################################
# SYSTEM
############################################

# 로그 레벨

LOG_LEVEL=INFO


# Timezone

TIMEZONE=UTC
