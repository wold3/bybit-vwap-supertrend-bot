# =====================================================
# Bybit API (실거래 / 테스트넷 선택 가능)
# =====================================================

BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_TESTNET=true


# =====================================================
# Telegram Bot
# =====================================================

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id


# =====================================================
# Database
# =====================================================

DB_TYPE=sqlite  # sqlite | postgres

SQLITE_PATH=./data/trading.db

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password


# =====================================================
# Trading Settings
# =====================================================

SYMBOL=BTCUSDT
TIMEFRAME=1m

INITIAL_EQUITY=1000


# =====================================================
# Risk Settings
# =====================================================

MAX_DAILY_LOSS=50
MAX_LOSS_STREAK=5

BASE_RISK=0.02


# =====================================================
# Execution Settings
# =====================================================

LEVERAGE_MAX=5
SLIPPAGE_BUFFER=0.0003
FEE_RATE=0.0006
