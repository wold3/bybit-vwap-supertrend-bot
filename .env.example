# =====================================
# Bybit API
# =====================================
BYBIT_API_KEY=YOUR_BYBIT_API_KEY
BYBIT_API_SECRET=YOUR_BYBIT_API_SECRET
TESTNET=True

# =====================================
# Trading
# =====================================
DEFAULT_SYMBOL=BTCUSDT
ORDER_QTY=0.001

WEBHOOK_SECRET=1234

MAX_TRADES_PER_MIN=3

# Risk Management
RISK_PER_TRADE=0.01
MAX_DAILY_LOSS=50
MAX_LOSS_STREAK=5

TAKE_PROFIT_PCT=1.5
STOP_LOSS_PCT=1.0

MIN_ORDER_QTY=0.001
MAX_ORDER_QTY=1.0

# =====================================
# Telegram
# =====================================
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# =====================================
# Flask
# =====================================
HOST=0.0.0.0
PORT=5000
DEBUG=False

# =====================================
# Logging
# =====================================
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# =====================================
# Database
# =====================================
DATABASE_URL=sqlite:///trading.db

# =====================================
# DQN / Reinforcement Learning
# =====================================
MODEL_PATH=models/best_model.pth

REPLAY_BUFFER_SIZE=10000
BATCH_SIZE=64

LEARNING_RATE=0.001
GAMMA=0.99

EPSILON=1.0
EPSILON_MIN=0.01
EPSILON_DECAY=0.995

TARGET_UPDATE=100

# =====================================
# Backtest
# =====================================
INITIAL_BALANCE=1000

# =====================================
# Watchdog
# =====================================
CHECK_INTERVAL=10
MAX_RESTART=20
